<div class="tab flexcol">
	<div class="form-group">
		<label>Active</label>
		<input type="checkbox" name="music-active" {{#if musicActive}}checked{{/if}}>
	</div>

	<div class="form-group">
		<label>Turn Only</label>
		<input type="checkbox" name="turn-only" {{#if turnOnly}}checked{{/if}}>
		<p class="hint">
			Whether the track should only play on the token's turn.
			<br />
			Priority is still respected -> will compete against other tracks with same priority.
		</p>
	</div>

	<div class="form-group slim">
		<label>Priority</label>
		<div class="form-fields">
			<input type="number" value="{{musicPriority}}" step="any" name="priority" placeholder="10" />
		</div>
		<p class="hint">The priority this token's playlist will compete against the others.</p>
	</div>

	<div class="form-group cmm-tracked-resource-row">
		<label>Tracked Resource</label>
		<div class="form-fields">
			<select class="bar-attribute" name="tracked-resource">
				{{selectOptions completeAttributes selected=trackedResource.attribute blank=(localize "None")}}
			</select>
			{{#unless isDefault}}
			<div class="form-fields bar-data">
				<input type="number" data-tracked-resource-value value="{{trackedResource.value}}" disabled />
				<span class="sep">/</span>
				<input type="number" data-tracked-resource-max value="{{trackedResource.max}}" disabled />
			</div>
			{{/unless}}
		</div>
	</div>

	<hr />

	<div class="form-group cmm-track-toolbar">
		<label>Actions</label>
		<div class="form-fields">
			<button type="button" data-action="previewTokenRule">
				<i class="fa-solid fa-play"></i> Preview Winner
			</button>
			<button type="button" data-action="applyToControlled">
				<i class="fa-solid fa-clone"></i> Apply To Controlled
			</button>
		</div>
	</div>

	<div class="track-selections">
		<header class="track-selection">
			<div class="track-selection-playlist">Playlist</div>
			<div class="track-selection-track">Track</div>
			<div class="track-selection-range">Value (%)</div>
			<div class="track-selection-controls track-selection-controls-header">
				<a class="action-button" data-action="addTrack" data-tooltip="Add Track">
					<i class="fa-solid fa-plus"></i>
				</a>
			</div>
		</header>
		{{!-- Each track selection --}}
		{{#each trackSelection}}
		<fieldset class="track-selection" data-index="{{@index}}">
			<div>
				<select name="playlist">
					<option value=""></option>
				</select>
			</div>

			<div>
				<select name="track">
					<option value=""></option>
				</select>
			</div>

			<div>
				<input name="threshold" type="number" value="{{this.threshold}}" min="0" max="100" step="any"
				{{#if this.disabled}}disabled{{/if}}>
			</div>
			<div class="track-selection-controls">
				<a class="action-button" data-action="previewRow" data-tooltip="Preview this row">
					<i class="fa-solid fa-play"></i>
				</a>
				<a class="action-button" data-action="stopRow" data-tooltip="Stop this row">
					<i class="fa-solid fa-stop"></i>
				</a>
				<a class="action-button {{#if this.disabled}}is-hidden{{/if}}" data-action="removeTrack" data-tooltip="Remove Track">
					<i class="fa-solid fa-times"></i>
				</a>
			</div>
			{{#if this.error}}
			<p class="hint" style="grid-column: 1 / -1; color: var(--color-level-error); margin-top: 4px;">
				Invalid music reference ({{this.error}}): {{this.flag}}
			</p>
			{{/if}}
		</fieldset>
		{{/each}}
	</div>
	{{#if hasInvalidEntries}}
	<p class="hint" style="color: var(--color-level-error); margin-top: 6px;">
		One or more configured music references are invalid or deleted. Save after correcting entries.
	</p>
	{{/if}}
</div>
