<div class="tab flexcol cmm-inspector">
	<p class="instructions cmm-inspector-summary">{{reason}}</p>
	<div class="form-group cmm-inspector-row">
		<label>Winner</label>
		<div class="form-fields">
			<input type="text" value="{{winnerLabel}}" disabled />
		</div>
	</div>
	{{#if overrideMusic}}
	<div class="form-group cmm-inspector-row">
		<label>Encounter Override</label>
		<div class="form-fields">
			<input type="text" value="{{overrideMusic}}" disabled />
		</div>
	</div>
	{{/if}}

	<hr />
	<h3 class="cmm-inspector-heading">Candidates</h3>
	{{#if candidates.length}}
	<ul class="cmm-playlists cmm-inspector-candidates">
		{{#each candidates}}
		<li class="cmm-inspector-candidate">
			<div class="cmm-inspector-candidate-main">
				<label>{{label}}</label>
			</div>
			<div class="cmm-inspector-candidate-meta">
				<span class="cmm-badge">P{{priority}}</span>
				{{#if token}}<span class="cmm-badge">Token {{token}}</span>{{/if}}
			</div>
		</li>
		{{/each}}
	</ul>
	{{else}}
	<p class="hint">No candidates available.</p>
	{{/if}}
</div>
